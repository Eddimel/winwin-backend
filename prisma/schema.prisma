generator client {
  provider   = "prisma-client-js"
  engineType = "client"
}

datasource db {
  provider = "postgresql"
}

enum CustomerStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

model Customer {
  id          String          @id @default(uuid())
  phone       String          @unique
  name        String
  email       String?
  company     String?
  isActive    Boolean         @default(true)
  status      CustomerStatus  @default(APPROVED)
  createdAt   DateTime        @default(now())

  sessions    CustomerSession[]
  otpCodes    OtpCode[]
  security    CustomerSecurity?
  orders      OrderDraft[]
}

model CustomerSecurity {
  id             String   @id @default(uuid())
  customerId     String   @unique
  failedAttempts Int      @default(0)
  lockedUntil    DateTime?
  updatedAt      DateTime @updatedAt
  customer       Customer @relation(fields: [customerId], references: [id])
}

model CustomerSession {
  id                 String   @id @default(uuid())
  customerId         String
  deviceHash         String
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  lastUsedAt         DateTime @updatedAt
  expiresAt          DateTime
  absoluteExpiresAt  DateTime

  customer Customer @relation(fields: [customerId], references: [id])

  @@index([customerId])
  @@index([expiresAt])
  @@index([absoluteExpiresAt])
}

model OtpCode {
  id         String   @id @default(uuid())
  customerId String
  code       String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  customer   Customer @relation(fields: [customerId], references: [id])
}

model Product {
  id                String   @id @default(uuid())
  shopifyProductId  String   @unique
  title             String
  description       String?
  imageUrl          String?
  tags              String?
  isActive          Boolean  @default(true)
  archived          Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  variants          ProductVariant[]
}

model ProductVariant {
  id                 String   @id @default(uuid())
  productId          String
  shopifyVariantId   String   @unique
  sku                String   @unique

  priceBase          Float
  priceB2B           Float?
  currency           String   @default("EUR")

  stock              Int      @default(0)
  moq                Int      @default(1)
  quantityMax        Int?

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  product            Product @relation(fields: [productId], references: [id])
  orderItems         OrderDraftItem[]
}

model OrderDraft {
  id         String   @id @default(uuid())
  customerId String
  status     String   @default("PENDING")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  customer   Customer @relation(fields: [customerId], references: [id])
  items      OrderDraftItem[]
}

model OrderDraftItem {
  id                String           @id @default(uuid())
  orderDraftId      String
  productVariantId  String
  requestedQuantity Int
  approvedQuantity  Int
  adjusted          Boolean          @default(false)
  createdAt         DateTime         @default(now())

  orderDraft        OrderDraft       @relation(fields: [orderDraftId], references: [id])
  productVariant    ProductVariant   @relation(fields: [productVariantId], references: [id])
}

model Shop {
  id           String   @id @default(uuid())
  shop         String   @unique
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  isApproved   Boolean  @default(false)
  accessToken  String
  refreshToken String?
  scope        String?
}