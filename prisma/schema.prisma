generator client {
  provider   = "prisma-client-js"
  engineType = "client"
}

datasource db {
  provider = "postgresql"
}

model Customer {
  id        String   @id @default(uuid())
  phone     String   @unique
  name      String
  email     String?
  company   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  sessions   CustomerSession[]
  otpCodes   OtpCode[]
  security   CustomerSecurity?
  orders     OrderDraft[]
}

model CustomerSecurity {
  id             String   @id @default(uuid())
  customerId     String   @unique
  customer       Customer @relation(fields: [customerId], references: [id])

  failedAttempts Int      @default(0)
  lockedUntil    DateTime?
  updatedAt      DateTime @updatedAt
}

model CustomerSession {
  id         String   @id @default(uuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])

  deviceHash String
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  lastUsedAt DateTime @updatedAt
}

model OtpCode {
  id         String   @id @default(uuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])

  code       String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
}

model Product {
  id          String   @id @default(uuid())
  sku         String   @unique
  name        String
  description String?
  isActive    Boolean  @default(true)

  stock       Int      @default(0)
  moq         Int
  quantityMax Int?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  orderItems  OrderDraftItem[]
}

model OrderDraft {
  id         String   @id @default(uuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])

  status     String   @default("PENDING")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  items      OrderDraftItem[]
}

model OrderDraftItem {
  id               String      @id @default(uuid())
  orderDraftId     String
  orderDraft       OrderDraft  @relation(fields: [orderDraftId], references: [id])

  productId        String
  product          Product     @relation(fields: [productId], references: [id])

  requestedQuantity Int
  approvedQuantity  Int
  adjusted          Boolean

  createdAt        DateTime @default(now())
}

model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model Shop {
  id         String   @id
  shop       String   @unique
  plan       String?  @default("free")
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime
  isApproved Boolean  @default(false)
}