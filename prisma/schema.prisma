generator client {
  provider   = "prisma-client-js"
  engineType = "client"
}

datasource db {
  provider = "postgresql"
}

model Customer {
  id        String   @id @default(uuid())
  phone     String   @unique
  name      String
  email     String?
  company   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  sessions   CustomerSession[]
  otpCodes   OtpCode[]
  security   CustomerSecurity?
  orders     OrderDraft[]
}

model CustomerSecurity {
  id             String   @id @default(uuid())
  customerId     String   @unique
  failedAttempts Int      @default(0)
  lockedUntil    DateTime?
  updatedAt      DateTime @updatedAt
  customer       Customer @relation(fields: [customerId], references: [id])
}

model CustomerSession {
  id                 String   @id @default(uuid())
  customerId         String
  deviceHash         String
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  lastUsedAt         DateTime @updatedAt
  expiresAt          DateTime
  absoluteExpiresAt  DateTime

  customer Customer @relation(fields: [customerId], references: [id])

  @@index([customerId])
  @@index([expiresAt])
  @@index([absoluteExpiresAt])
}

model OtpCode {
  id         String   @id @default(uuid())
  customerId String
  code       String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  customer   Customer @relation(fields: [customerId], references: [id])
}

model Product {
  id               String   @id @default(uuid())
  sku              String   @unique
  name             String
  description      String?
  isActive         Boolean  @default(true)
  stock            Int      @default(0)
  moq              Int      @default(1)
  quantityMax      Int?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  archived         Boolean  @default(false)
  currency         String   @default("EUR")
  imageUrl         String?
  priceB2B         Float?
  priceBase        Float
  shopifyProductId String?  @unique
  shopifyVariantId String?  @unique
  tags             String?
  orderItems       OrderDraftItem[]
}

model OrderDraft {
  id         String   @id @default(uuid())
  customerId String
  status     String   @default("PENDING")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  customer   Customer @relation(fields: [customerId], references: [id])
  items      OrderDraftItem[]
}

model OrderDraftItem {
  id                String     @id @default(uuid())
  orderDraftId      String
  productId         String
  requestedQuantity Int
  approvedQuantity  Int
  adjusted          Boolean    @default(false)
  createdAt         DateTime   @default(now())
  orderDraft        OrderDraft @relation(fields: [orderDraftId], references: [id])
  product           Product    @relation(fields: [productId], references: [id])
}

model Shop {
  id           String   @id @default(uuid())
  shop         String   @unique
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  isApproved   Boolean  @default(false)
  accessToken  String
  refreshToken String?
  scope        String?
}